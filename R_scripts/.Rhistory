library(tidyverse)
library(terra)
library(sf)
library(rnaturalearth)
library(ggplot2)
library(akima)
deepdata <- pacific_tad %>%
mutate(
deep_time = b100 + b150 + b200 + b_200
)
interp_data <- with(deepdata, interp(x = lon, y = lat, z = deep_time, duplicate = "mean"))
interp_df <- expand.grid(
lon = interp_data$x,
lat = interp_data$y
)
interp_df$deep_time <- as.vector(interp_data$z)
r <- rast(
interp_df,
type = "xyz",
crs = "EPSG:4326"
)
land <- ne_countries(scale = "medium", returnclass = "sf")
deepdata <- pacific_tad %>%
mutate(
deep_time = b100 + b150 + B200 + B_200
)
library("tidyverse")
library("janitor")
library("naniar")
library(akima)
library(viridis)
atlantic_argos <- read_csv("../input_files/AtlanticArgos.csv")
pacific_argos <- read_csv("../input_files/PacificArgos.csv")
pacific_tad <- read_csv("../input_files/Pacific_TAD.csv") %>%
clean_names()
atlantic_argos <- read_csv("../input_files/AtlanticArgos.csv")
pacific_argos <- read_csv("../input_files/PacificArgos.csv")
pacific_tad <- read_csv("../input_files/Pacific_TAD.csv") %>%
clean_names()
deepdata <- pacific_tad %>%
mutate(
deep_time = b100 + b150 + b200 + b_200
)
interp_data <- with(deepdata, interp(x = lon, y = lat, z = deep_time, duplicate = "mean"))
ggplot(interp_df, aes(x = lon, y = lat, fill = deep_time)) +
geom_raster() +
scale_fill_viridis_c(name = "Proportion Time >100 m", limits = c(0,1)) +
coord_fixed() +
theme_minimal() +
labs(
title = "Spatial Heatmap of Deep Diving Behavior",
x = "Longitude",
y = "Latitude"
)
deepdata <- pacific_tad %>%
mutate(
deep_time = b100 + b150 + b200 + b_200
)
interp_data <- with(deepdata, interp(x = lon, y = lat, z = deep_time, duplicate = "mean"))
interp_df <- expand.grid(
lon = interp_data$x,
lat = interp_data$y
)
interp_df$deep_time <- as.vector(interp_data$z)
ggplot(interp_df, aes(x = lon, y = lat, fill = deep_time)) +
geom_raster() +
scale_fill_viridis_c(name = "Proportion Time >100 m", limits = c(0,1)) +
coord_fixed() +
theme_minimal() +
labs(
title = "Spatial Heatmap of Deep Diving Behavior",
x = "Longitude",
y = "Latitude"
)
deepdata <- pacific_tad %>%
mutate(
deep_time = b100 + b150 + b200 + b_200
)
interp_data <- with(deepdata, interp(x = lon, y = lat, z = deep_time, duplicate = "mean"))
interp_df <- expand.grid(
lon = interp_data$x,
lat = interp_data$y
)
interp_df$deep_time <- as.vector(interp_data$z)
ggplot(interp_df, aes(x = lon, y = lat, fill = deep_time)) +
geom_raster() +
scale_fill_viridis_c(name = "Proportion Time >100 m",
limits = c(0,1),
option = "cividis") +
coord_fixed() +
theme_minimal() +
labs(
title = "Spatial Heatmap of Deep Diving Behavior",
x = "Longitude",
y = "Latitude"
)
deepdata <- pacific_tad %>%
mutate(
deep_time = b100 + b150 + b200 + b_200
)
interp_data <- with(deepdata, interp(x = lon, y = lat, z = deep_time, duplicate = "mean"))
interp_df <- expand.grid(
lon = interp_data$x,
lat = interp_data$y
)
interp_df$deep_time <- as.vector(interp_data$z)
ggplot(interp_df, aes(x = lon, y = lat, fill = deep_time)) +
geom_raster() +
scale_fill_viridis_c(name = "Proportion Time >100 m",
limits = c(0,1),
option = "cividis") +
coord_fixed() +
theme_minimal() +
labs(
x = "Longitude",
y = "Latitude"
)
sst_interp <- with(pacific_tad,
interp(x = lon, y = lat, z = SST, duplicate = "mean")
)
sst_interp <- with(pacific_tad,
interp(x = lon, y = lat, z = sst, duplicate = "mean")
)
sst_df <- expand.grid(
lon = sst_interp$x,
lat = sst_interp$y
)
sst_df$SST <- as.vector(sst_interp$z)
ggplot(sst_df, aes(lon, lat, fill = SST)) +
geom_raster() +
scale_fill_viridis_c(name = "Sea Surface Temp (°C)",
option = "magma") +
coord_fixed() +
theme_minimal() +
labs(
title = "Spatial Distribution of Sea Surface Temperature",
x = "Longitude",
y = "Latitude"
)
do_interp <- with(pacific_tad,
interp(x = lon, y = lat, z = do_depth, duplicate = "mean")
)
do_df <- expand.grid(
lon = do_interp$x,
lat = do_interp$y
)
do_df$DO_depth <- as.vector(do_interp$z)
ggplot(do_df, aes(lon, lat, fill = DO_depth)) +
geom_raster() +
scale_fill_viridis_c(name = "Hypoxic Boundary Depth (m)") +
coord_fixed() +
theme_minimal() +
labs(
title = "Depth of Hypoxic Boundary (DO = 3 ml/L)",
x = "Longitude",
y = "Latitude"
)
do_interp <- with(pacific_tad,
interp(x = lon, y = lat, z = do_depth, duplicate = "mean")
)
do_df <- expand.grid(
lon = do_interp$x,
lat = do_interp$y
)
do_df$DO_depth <- as.vector(do_interp$z)
ggplot(do_df, aes(lon, lat, fill = DO_depth)) +
geom_raster() +
scale_fill_viridis_c(name = "Hypoxic Boundary Depth (m)") +
coord_fixed() +
theme_minimal() +
labs(
x = "Longitude",
y = "Latitude"
)
sst_interp <- with(pacific_tad,
interp(x = lon, y = lat, z = sst, duplicate = "mean")
)
sst_df <- expand.grid(
lon = sst_interp$x,
lat = sst_interp$y
)
sst_df$SST <- as.vector(sst_interp$z)
ggplot(sst_df, aes(lon, lat, fill = SST)) +
geom_raster() +
scale_fill_viridis_c(name = "Sea Surface Temp (°C)",
option = "magma") +
coord_fixed() +
theme_minimal() +
labs(
x = "Longitude",
y = "Latitude"
)
depth_long <- pacific_tad %>%
pivot_longer(
cols = c(b0, b50, b100, b150, b200, b_200),
names_to = "depth_bin",
values_to = "prop_time"
)
depth_long <- pacific_tad %>%
pivot_longer(
cols = c(b50, b100, b150, b200, b_200),
names_to = "depth_bin",
values_to = "prop_time"
)
depth_long <- pacific_tad %>%
pivot_longer(
cols = c(b_50, b100, b150, b200, b_200),
names_to = "depth_bin",
values_to = "prop_time"
)
ggplot(depth_long, aes(x = do, y = prop_time)) +
geom_point(alpha = 0.5) +
facet_wrap(~depth_bin) +
theme_minimal() +
labs(
title = "Dissolved Oxygen vs Time Spent at Depth",
x = "Dissolved Oxygen",
y = "Proportion of Time"
)
View(depth_long)
depth_long <- pacific_tad %>%
pivot_longer(
cols = c(b_50, b100, b150, b200, b_200),
names_to = "depth_bin",
values_to = "prop_time"
)
depth_long %>%
ggplot(
mapping = aes(x = do_depth, y = prop_time)
)+
geom_point(alpha = 0.5) +
facet_wrap(~depth_bin) +
theme_minimal() +
labs(
title = "Dissolved Oxygen vs Time Spent at Depth",
x = "Dissolved Oxygen",
y = "Proportion of Time"
)
View(pacific_tad)
pacific_tad %>%
select(id, do_depth, b_50)
ggplot(
mapping = aes(
x = do_depth,
y = b_50)
)+
geom_point(
alpha = 0.5)+
geom_line(
se = FALSE,
method = lm
)+
theme_classic()+
labs(
x = "Dissolved Oxygen",
y = "Proportion of Time"
)
